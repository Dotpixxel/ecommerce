{
	"name": "web",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "rm -rf dist && vite build",
		"build:staging": "rm -rf dist && vite build --mode staging",
		"serve": "vite preview",
		"dev": "vite dev",
		"lint": "biome check .",
		"typecheck": "tsc --noEmit",
		"deploy:staging": "CLOUDFLARE_ENV=staging pnpm run build:staging && wrangler deploy --env staging",
		"deploy:production": "CLOUDFLARE_ENV=production pnpm run build && wrangler deploy --env production"
	},
