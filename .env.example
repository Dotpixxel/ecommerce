# ── Database ────────────────────────────────────────────────────────────────
# Local dev: SQLite dosyası (Turso cloud gerekmez)
DATABASE_URL="file:../../local.db"
DATABASE_AUTH_TOKEN=""

# Production (Turso cloud):
# DATABASE_URL="libsql://your-db-name.turso.io"
# DATABASE_AUTH_TOKEN="eyJ..."

# ── Authentication ───────────────────────────────────────────────────────────
BETTER_AUTH_URL="http://localhost:3001"
# openssl rand -base64 32 ile üretin
BETTER_AUTH_SECRET="your-better-auth-secret-minimum-32-characters"
CORS_ORIGIN="http://localhost:3001"

# ── Node Environment ─────────────────────────────────────────────────────────
NODE_ENV="development"

# ── Storage ──────────────────────────────────────────────────────────────────
# local → dosyalar public/local-uploads/ içine, hiç S3 gerekmez (local dev için önerilen)
# s3    → MinIO veya Cloudflare R2
STORAGE_PROVIDER="local"

# STORAGE_PROVIDER=s3 ise doldurun:
# MinIO local dev:
# R2_ENDPOINT="http://localhost:9000"
# R2_BUCKET_NAME="dev-bucket"
# R2_ACCESS_KEY_ID="minio"
# R2_SECRET_ACCESS_KEY="minio123"
# R2_PUBLIC_DOMAIN="http://localhost:9000/dev-bucket"
#
# Cloudflare R2 (production):
# R2_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"
# R2_BUCKET_NAME="your-bucket-name"
# R2_ACCESS_KEY_ID="your-access-key-id"
# R2_SECRET_ACCESS_KEY="your-secret-access-key"
# R2_PUBLIC_DOMAIN="https://cdn.yourdomain.com"

# ── Payment ───────────────────────────────────────────────────────────────────
# iyzico | stripe
PAYMENT_PROVIDER="iyzico"

# Iyzico (sandbox için sandbox-api.iyzipay.com, production için api.iyzipay.com)
IYZICO_API_KEY="sandbox-your-api-key"
IYZICO_SECRET_KEY="sandbox-your-secret-key"
IYZICO_BASE_URL="https://sandbox-api.iyzipay.com"

# Stripe (PAYMENT_PROVIDER=stripe ise doldurun)
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Email ─────────────────────────────────────────────────────────────────────
# development modunda email console'a yazılır (gönderilmez)
# smtp | resend
EMAIL_PROVIDER="smtp"
EMAIL_FROM="Raunk Butik <noreply@yourdomain.com>"

# SMTP (Gmail örneği — App Password gerekli):
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="your@gmail.com"
# SMTP_PASS="xxxx-xxxx-xxxx-xxxx"

# Resend (ileride kullanım için — EMAIL_PROVIDER=resend):
# RESEND_API_KEY="re_..."

# ── Google OAuth (Opsiyonel) ─────────────────────────────────────────────────
# GOOGLE_CLIENT_ID="your-google-client-id"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"
